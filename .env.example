# ── Application ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
APP_NAME="WhatsApp Order Manager"

# ── Database ─────────────────────────────────────────────────────────────────────
# Local PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/whatsapp_orders

# ── Security ─────────────────────────────────────────────────────────────────────
# Generate with: python scripts/generate_encryption_key.py
ENCRYPTION_KEY=                  # Required: Fernet 32-byte URL-safe base64 key
JWT_SECRET_KEY=                  # Required: random 64-char string (openssl rand -hex 32)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ── Meta App (from https://developers.facebook.com) ──────────────────────────────
META_APP_ID=                      # Your Meta Business App ID
META_APP_SECRET=                  # Meta App Secret (used for token exchange)

# ── OAuth URLs ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ── WhatsApp / Meta Cloud API ────────────────────────────────────────────────────
WHATSAPP_TOKEN=                  # EAAxxxx... from Meta Business Manager (optional fallback)
PHONE_NUMBER_ID=                 # Numeric phone number ID from Meta (optional fallback)
WEBHOOK_VERIFY_TOKEN=            # Any random string — must match Meta dashboard setting

# ── Redis / Celery ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── CORS ─────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ────────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=10/15minutes    # Applied to /auth/login and /auth/register

# ── Error Monitoring (optional) ──────────────────────────────────────────────────
SENTRY_DSN=                      # https://xxx@sentry.io/yyy — leave blank to disable
